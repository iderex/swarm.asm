# Normalize all text files to LF in the repository AND the working tree, so line
# endings are deterministic across operating systems and no CRLF churn ever
# enters history. FASM accepts LF sources; Prettier is configured for LF.
* text=auto eol=lf

# PowerShell scripts run on Windows hosts — keep native line endings there.
*.ps1 text eol=crlf

# Binary assets — never normalized or diffed as text.
*.png binary
*.jpg binary
*.ico binary
*.zip binary
